# Copy to .env (gitignored). Prefer the OS keychain via `scripts/store_keys.py`;
# env vars are the fallback. NEVER commit real keys. Keys are never logged.

# --- Paper (default mode) ---
ALPACA_PAPER_KEY_ID=
ALPACA_PAPER_SECRET_KEY=

# --- Live (leave blank until the paper->live gate is passed) ---
ALPACA_LIVE_KEY_ID=
ALPACA_LIVE_SECRET_KEY=

# Mode is set in config/*.yaml and defaults to paper. This env var can only
# FORCE paper (safety override for shared machines); it cannot force live.
ROBOTRADER_FORCE_PAPER=

# --- Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=
HEALTHCHECKS_URL=
